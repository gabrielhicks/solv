#/bin/bash

# Constants and configurable variables
NODE_VERSION=24.16.0

# This ensures the entire script is downloaded
{
set -e  # exit immediately if a command exits with a non-zero status

usage() {
    cat 1>&2 <<EOF
Custom Install Script
Creates a new user 'solv', adds the user to the sudo group, logs in as 'solv',
installs pnpm, node $NODE_VERSION, and sets it as the global version.
Additionally, installs the @gabrielhicks/solv package globally.

USAGE:
    custom-install-script.sh [FLAGS]

FLAGS:
    -h, --help              Prints help information
EOF
}

create_user() {
    if getent passwd solv >/dev/null 2>&1; then
        echo "User 'solv' already exists, skipping..."
    else
        echo "Creating user 'solv'..."
        sudo adduser solv
        sudo usermod -aG sudo solv
        echo "solv ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/solv
    fi
}

install_docker() {
    echo "Installing Docker..."
    sudo apt update
    sudo apt install apt-transport-https ca-certificates curl software-properties-common -y
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
    sudo apt update
    sudo apt install docker-ce -y
    sudo systemctl enable docker
    sudo systemctl start docker
    sudo usermod -aG docker solv
}


setup_firewall() {
    echo "Configuring firewall"
    echo "yes" | sudo ufw enable
    sudo ufw default deny incoming
    sudo ufw default allow outgoing
    sudo ufw allow 22/tcp
    sudo ufw allow 8899/udp
    sudo ufw allow 8899/tcp
    sudo ufw allow 8000:8898/udp
    sudo ufw allow 8000:8898/tcp
    sudo ufw deny proto tcp from any to any port 8000:8025
    sudo ufw allow 8900:10000/tcp
    sudo ufw allow 8900:10000/udp
    sudo ufw allow 179/tcp
    sudo ufw allow in on doublezero0 to any port 44880 proto udp
    sudo ufw allow out on doublezero0 to any port 44880 proto udp
    sudo ufw allow 9600/tcp
    sudo ufw reload
}

setup_lib() {
    echo "Installing Packages..."
    sudo apt install fail2ban ipset iptables python3-venv jq -y
    sudo apt-get install libsasl2-dev build-essential -y
    sudo apt-get install -y libssl-dev libudev-dev pkg-config zlib1g-dev llvm clang cmake make libprotobuf-dev protobuf-compiler libclang-18-dev clang-18 llvm-18-dev
}

install_rustup() {
    sudo su - solv <<EOF_SOLV
        echo "Installing rustup..."
        curl https://sh.rustup.rs -sSf | sh -s -- -y
        echo 'export PATH="\$HOME/.cargo/env:\$PATH"' >> ~/.profile
        source ~/.cargo/env
        rustup component add rustfmt
        rustup update
EOF_SOLV
}

install_pnpm_and_packages() {
    # Heal ownership: prior install runs (or `solv update` invoked as root)
    # can leave root-owned files under solv's pnpm dir, causing EACCES on rmdir.
    if [ -d /home/solv/.local/share/pnpm ]; then
        echo "Fixing ownership of /home/solv/.local/share/pnpm..."
        sudo chown -R solv:solv /home/solv/.local/share/pnpm
    fi

    sudo su - solv <<EOF_SOLV
        set -e

        # Do NOT pre-export PNPM_HOME — pnpm's installer/setup will short-circuit
        # ("No changes to the environment were made") and skip copying the binary.
        echo "Installing pnpm..."
        curl -fsSL https://get.pnpm.io/install.sh | sh -

        # Locate the pnpm binary regardless of where the installer put it.
        # Newer pnpm puts the binary at \$HOME/.local/share/pnpm/bin/pnpm; older versions used \$HOME/.local/share/pnpm/pnpm.
        PNPM_BIN=""
        for candidate in \\
            "\$HOME/.local/share/pnpm/bin/pnpm" \\
            "\$HOME/.local/share/pnpm/pnpm" \\
            "/home/solv/.local/share/pnpm/bin/pnpm" \\
            "/home/solv/.local/share/pnpm/pnpm" \\
            "\$HOME/.pnpm/pnpm"; do
            if [ -x "\$candidate" ]; then
                PNPM_BIN="\$candidate"
                break
            fi
        done
        if [ -z "\$PNPM_BIN" ]; then
            PNPM_BIN=\$(find "\$HOME" -maxdepth 6 -type f -name pnpm -executable 2>/dev/null | head -n 1)
        fi
        if [ -z "\$PNPM_BIN" ] || [ ! -x "\$PNPM_BIN" ]; then
            echo "ERROR: could not locate pnpm binary after install" >&2
            echo "DEBUG: listing \$HOME/.local/share:" >&2
            ls -laR "\$HOME/.local/share" 2>&1 | head -100 >&2 || true
            exit 1
        fi
        echo "Found pnpm at: \$PNPM_BIN"

        # Derive PNPM_HOME and the global-bin dir.
        # New layout: pnpm at \$PNPM_HOME/bin/pnpm; global bins also in \$PNPM_HOME/bin.
        # Old layout: pnpm at \$PNPM_HOME/pnpm; global bins also in \$PNPM_HOME.
        PNPM_BIN_DIR="\$(dirname "\$PNPM_BIN")"
        if [ "\$(basename "\$PNPM_BIN_DIR")" = "bin" ]; then
            PNPM_HOME="\$(dirname "\$PNPM_BIN_DIR")"
            PNPM_GLOBAL_BIN="\$PNPM_BIN_DIR"
        else
            PNPM_HOME="\$PNPM_BIN_DIR"
            PNPM_GLOBAL_BIN="\$PNPM_BIN_DIR"
        fi
        export PNPM_HOME
        export PATH="\$PNPM_GLOBAL_BIN:\$PATH"
        echo "PNPM_HOME=\$PNPM_HOME  global-bin=\$PNPM_GLOBAL_BIN"

        echo "export PNPM_HOME=\"\$PNPM_HOME\"" >> ~/.profile
        echo "export PATH=\"\$PNPM_GLOBAL_BIN:\\\$PATH\"" >> ~/.profile
        echo 'export LIBCLANG_PATH=/usr/lib/llvm-18/lib' >> ~/.profile
        echo 'export CLANG_PATH=/usr/bin/clang-18' >> ~/.profile
        echo 'export PATH="/home/solv/.local/share/solana/install/active_release/bin:\$PATH"' >> ~/.profile

        echo "Installing node $NODE_VERSION..."
        "\$PNPM_BIN" runtime set node $NODE_VERSION -g

        echo "Installing @gabrielhicks/solv..."
        "\$PNPM_BIN" add -g --prefer-online @gabrielhicks/solv@latest

        SOLV_BIN="\$PNPM_GLOBAL_BIN/solv"
        if [ ! -x "\$SOLV_BIN" ]; then
            SOLV_BIN=\$(find "\$HOME" -maxdepth 6 -type f -name solv -executable 2>/dev/null | head -n 1)
        fi
        if [ -z "\$SOLV_BIN" ] || [ ! -x "\$SOLV_BIN" ]; then
            echo "ERROR: could not locate solv binary after install" >&2
            exit 1
        fi
        echo "Found solv at: \$SOLV_BIN"

        "\$SOLV_BIN" i
        "\$SOLV_BIN" get aa
EOF_SOLV
}



main() {
    for arg in "$@"; do
      case "$arg" in
        -h|--help)
          usage
          exit 0
          ;;
        *)
          ;;
      esac
    done

    create_user
    setup_firewall
    setup_lib
    install_docker
    install_rustup
    install_pnpm_and_packages
    echo "Enter solv user password 👇"
    su solv
}

main "$@"

} # this ensures the entire script is downloaded